int strStr(char* haystack, char* needle) {
    int n = strlen(haystack);
    int m = strlen(needle);

    // If needle is longer than haystack, it can't be a substring
    if (m > n) {
        return -1;
    }

    // Iterate through the haystack
    // We only need to go up to (n - m) because after that, 
    // there aren't enough characters left to match the needle.
    for (int i = 0; i <= n - m; i++) {
        int j = 0;
        
        // Check if characters match starting from index i
        while (j < m && haystack[i + j] == needle[j]) {
            j++;
        }

        // If we reached the end of the needle, we found a match
        if (j == m) {
            return i;
        }
    }

    return -1;
}
    
