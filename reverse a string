void reverse(char* s,int start,int end)
{
    while(start<end)
    {
        char temp=s[start];
        s[start++]=s[end];
        s[end--]=temp;
    }
}

char* reverseWords(char* s) {
    int n = strlen(s);
    int writeIdx = 0;

    // Step 1: Reverse the entire string
    reverse(s, 0, n - 1);

    // Step 2: Iterate through the reversed string to find words
    for (int i = 0; i < n; i++) {
        if (s[i] != ' ') {
            // Add a single space before words, but not at the very beginning
            if (writeIdx != 0) s[writeIdx++] = ' ';

            int wordStart = writeIdx;
            // Move the word to the current write position
            while (i < n && s[i] != ' ') {
                s[writeIdx++] = s[i++];
            }
            
            // Step 3: Reverse the word back to normal
            reverse(s, wordStart, writeIdx - 1);
        }
    }

    // Null terminate the result to cut off old trailing characters
    s[writeIdx] = '\0';
    return s;
}
