int hIndex(int* citations, int citationsSize) {
    int n = citationsSize;
    
    // Create buckets to store the count of papers for each citation count.
    // We use n+1 because the maximum possible h-index is n.
    // calloc initializes the memory to zero.
    int* buckets = (int*)calloc(n + 1, sizeof(int));
    
    for (int i = 0; i < n; i++) {
        if (citations[i] >= n) {
            buckets[n]++;
        } else {
            buckets[citations[i]]++;
        }
    }
    
    int totalPapers = 0;
    // Iterate from the back of the buckets
    for (int i = n; i >= 0; i--) {
        totalPapers += buckets[i];
        
        // According to the definition: 
        // at least 'i' papers have at least 'i' citations.
        if (totalPapers >= i) {
            free(buckets); // Don't forget to free allocated memory
            return i;
        }
    }
    
    free(buckets);
    return 0;
}
