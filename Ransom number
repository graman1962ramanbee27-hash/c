
bool canConstruct(char * ransomNote, char * magazine) {
    // A frequency array for the 26 lowercase English letters
    int counts[26] = {0};
    
    // Quick check: if note is longer than magazine, it's impossible
    if (strlen(ransomNote) > strlen(magazine)) {
        return false;
    }

    // Fill the frequency array with characters from the magazine
    for (int i = 0; magazine[i] != '\0'; i++) {
        counts[magazine[i] - 'a']++;
    }

    // Iterate through the ransomNote and subtract counts
    for (int i = 0; ransomNote[i] != '\0'; i++) {
        int index = ransomNote[i] - 'a';
        
        // Decrement the count for this character
        counts[index]--;
        
        // If the count goes below 0, it means the magazine 
        // didn't have enough of this character.
        if (counts[index] < 0) {
            return false;
        }
    }

    return true;
}
