int majorityElement(int* nums, int numsSize) {
    int k=0,count=0;
    for(int i=0;i<numsSize;i++)
    {
        if(count==0)
        {
         k=nums[i];
        }
        if(nums[i]==k)
        {
         count++;
        }
        else
        {
            count--;
        }
    }
    return k;
    
}
